<div
            class="p-3 d-flex mb-0 align-items-center justify-content-between"
          >
            <div class="d-flex align-items-center">
              <div class="avatar-xs flex-shrink-0 me-3">
                <div class="avatar-title bg-primary text-light rounded-3">
                  {{ assessment.name.charAt(0) | uppercase }}
                </div>
              </div>
              <div class="flex-grow-1">
                <h5 class="fs-13 mb-0 text-truncate flex-grow-1">
                  <a
                    href="javascript:void(0);"
                    class="text-body d-block"
                    (click)="setCurrentAssessment(assessment)"
                    routerLink="/examalpha/exams/{{
                      assessment.id
                    }}/exam-schedule"
                    >{{ assessment.name }}</a
                  >
                </h5>
                <p
                  class="text-secondary p-0 m-0"
                  style="font-size: 12px; font-weight: lighter"
                >
                  {{ assessment.createdDate | date : "medium" }}
                </p>
              </div>
            </div>

            <div class="d-flex gap-4 justify-content-end">
              <span class="fs-12 py-1 px-2" *ngIf="assessment.totalCenters">
                <span class="border rounded-2">
                  <i
                    class="ri-check-double-line text-success p-2 align-middle"
                  ></i>
                </span>
                Centers
              </span>
              <span
                class="fs-12 py-1 px-2"
                *ngIf="assessment.totalCenterAdmins"
              >
              <span class="border rounded-2">
                <i
                  class="ri-check-double-line text-success p-2 align-middle"
                ></i>
              </span>
                Admins
              </span>
              <span
                class="fs-12 p-1 py-1"
                *ngIf="assessment.totalSectionsGroup"
              >
                <span class="border rounded-2">
                  <i
                    class="ri-check-double-line text-success p-2 align-middle"
                  ></i>
                </span>
                Section Groups
              </span>
              <span
                class="fs-12 px-1 py-1"
                *ngIf="assessment.totalParticipants"
              >
                <span class="border rounded-2">
                  <i
                    class="ri-check-double-line text-success p-2 align-middle"
                  ></i>
                </span>

                Participants
              </span>

              <!-- assessment status -->
              <div>
                <span
                  class="text-capitalize rounded-2 fs-12"
                  [ngClass]="{
                    ' p-1 py-0 px-1  ': assessment.status === 'PUBLISHED',
                    ' p-1 py-0 ': assessment.status === 'DRAFT'
                  }"
                  ><i
                    *ngIf="assessment.status === 'DRAFT'"
                    class="ri-draft-line align-bottom"
                  ></i>
                  <i
                    *ngIf="assessment.status === 'PUBLISHED'"
                    class="ri-checkbox-circle-line align-bottom text-white"
                  ></i>
                </span>
                <span class="fs-12">Status:</span>
                <span
                  class="text-capitalize fs-12"
                  [ngClass]="{
                    'text-success': assessment.status === 'PUBLISHED',
                    'text-warning': assessment.status === 'DRAFT'
                  }"
                >
                  {{ assessment.status }}</span
                >
              </div>

              <div class="dropdown" ngbDropdown>
                <a
                  class="text-muted arrow-none"
                  id="dropdownMenuLink1"
                  data-bs-toggle="dropdown"
                  aria-expanded="false"
                  ngbDropdownToggle
                  ><i
                    class="ri-more-2-fill align-middle me-2 fs-18 fw-bold text-dark"
                    style="cursor: pointer"
                  ></i
                ></a>
                <ul
                  class="dropdown-menu dropdown-menu-end"
                  aria-labelledby="dropdownMenuLink1"
                  ngbDropdownMenu
                >
                  <li>
                    <a
                      class="dropdown-item"
                      (click)="setCurrentAssessment(assessment)"
                      routerLink="/examalpha/schedule/{{
                        assessment.id
                      }}/exam-schedule"
                      ><i class="bx bxs-edit align-bottom me-2 text-muted"></i>
                      Manage Schedule</a
                    >
                  </li>
